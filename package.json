{
  "name": "stellar-trust-escrow",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev -w frontend & npm run dev -w backend",
    "build": "npm run lint-staged && npm run build -w frontend",
    "install": "npm run -w backend && npm run  -w frontend",
    "lint": "eslint .",
    "lint:sol": "solhint \"contracts/**/*.sol\"",
    "lint-staged": "npx lint-staged",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "npm run test -w frontend && npm run test -w backend",
    "loadtest:generate": "node load-tests/data/generate.js",
    "loadtest": "node load-tests/run.js",
    "loadtest:ci": "node load-tests/run.js --ci",
    "prepare": "husky install",
    "fix": "npm run lint:fix && npm run format"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "autocannon": "^8.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-solidity": "^2.3.1",
    "solhint": "^6.1.0",
    "typescript-eslint": "^8.57.1",
    "url-parse": "^1.5.10",
    "validate-branch-name": "^1.3.2"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,md}": [
      "prettier --write"
    ],
    "*.{js,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "validate-branch-name": {
    "pattern": "^(main|develop|live){1}$|^(feature|fix|refactor|hotfix|release|conflict)/NV-[0-9]{1,5}.*$",
    "errorMsg": "Branch name structure: feature/NV-1234-new-feature\nAllowed prefixes: feature, fix, refactor, hotfix, release, conflict"
  },
  "dependencies": {
    "@prisma/client": "^7.5.0",
    "@sentry/node": "^10.46.0",
    "@stellar/stellar-sdk": "^14.6.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "csv-stringify": "^6.7.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "prom-client": "^15.1.3",
    "redis": "^5.11.0",
    "safer-buffer": "^2.1.2",
    "stripe": "^21.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tough-cookie": "^6.0.1",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  }
}
